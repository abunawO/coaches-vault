<div class="container">
  <% if current_user.coach? %>
    <%= render "shared/page_header",
          breadcrumbs: [["Dashboard", root_path]],
          title: content_tag(:span, "📊", class: "page-title-icon") + " Coach dashboard",
          subtitle: current_user.coach_profile&.display_name || "Overview of your vault.",
          primary_action: { label: "New Lesson", url: new_coach_lesson_path(return_to: request.fullpath) },
          secondary_actions: [
            { label: "Manage content", url: coach_content_path },
            (current_user.coach_profile.present? ? { label: "View public page", url: coach_path(current_user.coach_profile.slug), class: "btn btn-ghost" } : nil)
          ].compact,
          meta: [
            { label: "Lessons", value: (@lesson_count || 0) },
            { label: "Subscribers", value: (@subscriber_count || 0) }
          ] %>

    <div class="grid-3">
      <div class="mv-card">
        <div class="mv-card__header" style="align-items:flex-end;">
          <div>
            <span class="muted">Total lessons</span>
            <h3 class="mv-card__title" style="font-size:1.4rem; margin-top:4px;"><%= @lesson_count || 0 %></h3>
          </div>
        </div>
      </div>
      <div class="mv-card">
        <div class="mv-card__header" style="align-items:flex-end;">
          <div>
            <span class="muted">Locked lessons</span>
            <h3 class="mv-card__title" style="font-size:1.4rem; margin-top:4px;">—</h3>
          </div>
        </div>
      </div>
      <div class="mv-card">
        <div class="mv-card__header" style="align-items:flex-end;">
          <div>
            <span class="muted">Subscribers</span>
            <h3 class="mv-card__title" style="font-size:1.4rem; margin-top:4px;"><%= @subscriber_count || 0 %></h3>
          </div>
        </div>
      </div>
    </div>

    <section class="section">
      <div class="section-header">
        <h2>Recent lessons</h2>
      </div>
      <% if @recent_lessons.present? %>
        <div class="grid">
          <% @recent_lessons.each do |lesson| %>
            <% thumbnail = lesson_thumbnail_url(lesson) %>
            <div class="mv-card coach-dashboard-lesson-card">
              <div class="coach-dashboard-lesson-card__media">
                <% if thumbnail.present? %>
                  <img src="<%= thumbnail %>" alt="<%= lesson.title %> cover" class="coach-dashboard-lesson-card__image" loading="lazy" decoding="async" />
                <% else %>
                  <div class="coach-dashboard-lesson-card__image-placeholder" aria-hidden="true">
                    <span class="coach-dashboard-lesson-card__placeholder-label">Lesson Preview</span>
                  </div>
                <% end %>
              </div>

              <div class="coach-dashboard-lesson-card__body">
                <h3 class="mv-card__title"><%= lesson.title %></h3>
                <% if lesson.description.present? %>
                  <p class="mv-card__subtitle"><%= truncate(lesson.description, length: 110) %></p>
                <% end %>
                <div class="mv-card__meta">
                  <span>📅 <%= time_ago_in_words(lesson.created_at) %> ago</span>
                </div>

                <div class="mv-card__actions">
                  <%= link_to lesson_path(lesson), class: "btn-icon icon-btn", aria: { label: "View" }, data: { tooltip: "View" } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 9s3-6 11-6 11 6 11 6-3 6-11 6S1 9 1 9Z"/><circle cx="12" cy="9" r="2.5"/></svg>
                  <% end %>
                  <%= link_to edit_coach_lesson_path(lesson), class: "btn-icon icon-btn", aria: { label: "Edit" }, data: { tooltip: "Edit" } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4Z"/></svg>
                  <% end %>
                  <button type="button"
                          class="btn-icon btn-icon-danger icon-btn icon-btn--danger card-action--danger"
                          data-action="confirm-modal#open"
                          data-confirm-title="Delete lesson?"
                          data-confirm-body="This will permanently delete this lesson. This cannot be undone."
                          data-confirm-action="<%= coach_lesson_path(lesson) %>"
                          data-confirm-method="delete"
                          data-confirm-label="Delete"
                          aria-label="Delete"
                          data-tooltip="Delete">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M15 6V4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v2"/></svg>
                  </button>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state",
            icon: "📚",
            title: "Your vault is ready — let’s build it",
            body: "Start by creating your first lesson. Once published, students can subscribe and begin learning from you.",
            primary_action: { label: "Create your first lesson", url: new_coach_lesson_path(return_to: request.fullpath) },
            secondary_action: { label: "View public page", url: public_vault_path } %>
      <% end %>
    </section>

  <% else %>
    <section class="card dashboard-hero">
      <% student_profile = current_user.student_profile %>
      <% initials = current_user.display_name.to_s.first(2).upcase %>
      <div class="dashboard-hero__top">
        <div class="dashboard-hero__identity">
          <div class="hero__avatar">
            <% if student_profile&.avatar&.attached? %>
              <% begin %>
                <%= image_tag url_for(student_profile.avatar.variant(resize_to_fill: [48, 48])), alt: student_profile.display_name, class: "avatar-img" %>
              <% rescue StandardError %>
                <%= image_tag url_for(student_profile.avatar), alt: student_profile.display_name, class: "avatar-img" %>
              <% end %>
            <% else %>
              <span class="avatar-fallback"><%= initials %></span>
            <% end %>
          </div>
          <div class="dashboard-hero__text">
            <div class="hero__kicker muted">Dashboard</div>
            <div class="hero__name">Welcome back, <%= current_user.display_name %></div>
            <div class="hero__meta"><%= student_profile&.location.presence || current_user.display_name %></div>
            <div class="dashboard-hero__chips">
              <span class="pill chip-status dashboard-hero__chip"><%= current_user.role.capitalize %></span>
              <% if current_user.student? %>
                <span class="pill chip-meta dashboard-hero__chip">Subscriptions: <%= @subscription_count || 0 %></span>
              <% end %>
            </div>
          </div>
        </div>
        <div class="dashboard-hero__actions">
          <% if current_user.student? %>
            <%= link_to "Edit profile", edit_my_student_profile_path, class: "btn btn-secondary btn--compact" %>
          <% end %>
          <%= link_to "Refresh", root_path, class: "btn btn-ghost btn--compact" %>
        </div>
      </div>
    </section>

    <% if @recommended_system.present? %>
      <% system_category = @recommended_system[:category] %>
      <% system_coach_profile = @recommended_system[:coach_profile] %>
      <% system_thumb = lesson_thumbnail_url(@recommended_system[:representative_lesson], size: [1200, 675]) %>
      <% system_path = coach_public_vault_path(system_coach_profile.slug, category_id: system_category.id) %>
      <% recommendation_mode = @recommended_system[:mode].to_s %>
      <% recommendation_heading =
           case recommendation_mode
           when "continue" then "Continue This System"
           when "new_in_vault" then "New in Your Vault"
           else "Study This System"
           end %>
      <% recommendation_copy =
           case recommendation_mode
           when "continue" then "Pick up where you left off in the vault."
           when "new_in_vault" then "This system has fresh lessons ready to study."
           else "Enter the vault through a focused system instead of random lessons."
           end %>
      <% recommendation_cta =
           case recommendation_mode
           when "continue" then "Continue in Vault"
           when "new_in_vault" then "See What’s New"
           else "Study in Vault"
           end %>
      <section class="section study-system">
        <div class="study-system__header section-header">
          <div>
            <p class="study-system__eyebrow muted">Structured Learning</p>
            <h2 class="study-system__title"><%= recommendation_heading %></h2>
            <p class="muted"><%= recommendation_copy %></p>
          </div>
        </div>

        <%= link_to system_path, class: "study-system__card card" do %>
          <div class="study-system__media">
            <% if system_thumb.present? %>
              <img src="<%= system_thumb %>" alt="<%= system_category.name %> system preview" class="study-system__image" loading="lazy" decoding="async" />
            <% else %>
              <div class="study-system__image-placeholder" aria-hidden="true">
                <span>System Preview</span>
              </div>
            <% end %>
          </div>

          <div class="study-system__body">
            <div class="study-system__meta">
              <span class="pill-soft chip-meta"><%= system_category.category_type %></span>
              <span class="pill-soft chip-meta"><%= pluralize(@recommended_system[:lesson_count], "lesson") %></span>
            </div>
            <h3 class="study-system__name"><%= system_category.name %></h3>
            <p class="study-system__coach muted">by <%= @recommended_system[:coach_name] %></p>
            <% if system_category.description.present? %>
              <p class="study-system__description muted"><%= truncate(system_category.description, length: 120) %></p>
            <% end %>
            <% if @recommended_system[:preview_titles].any? %>
              <div class="study-system__lessons muted">
                <p class="study-system__lessons-label">Focus lessons</p>
                <ul class="study-system__lessons-list">
                  <% @recommended_system[:preview_titles].first(2).each do |title| %>
                    <li><%= title %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>
            <span class="study-system__cta"><%= recommendation_cta %></span>
          </div>
        <% end %>
      </section>
    <% end %>

    <section class="section">
      <div class="section-header">
        <div>
          <p class="muted">Explore Vaults</p>
          <h2>Featured lessons</h2>
        </div>
      </div>

      <div class="video-grid">
        <% @feed_lessons.each do |lesson| %>
          <% coach_profile = lesson.coach&.coach_profile %>
          <% coach_name = coach_profile&.display_name || lesson.coach&.email || "Coach" %>
          <% access_level = lesson.viewer_access_level(current_user) %>
          <% lesson_view = @lesson_views_by_lesson_id.to_h[lesson.id] %>
          <% learning_state = lesson.learning_state_for(current_user, access_level: access_level, lesson_view: lesson_view) %>
          <% learning_state_class = learning_state.to_s.tr("_", "-") %>
          <% learning_state_label =
               case learning_state
               when :locked then "Locked"
               when :new then "New"
               else nil
               end %>
          <% open_path = if coach_profile&.slug && lesson.respond_to?(:slug) && lesson.slug.present?
                           public_coach_lesson_path(coach_profile.slug, lesson.slug)
                         elsif coach_profile&.slug
                           public_coach_lesson_path(coach_profile.slug, lesson)
                         else
                           lesson_path(lesson)
                         end %>
          <% locked_path = coach_profile&.slug ? coach_path(coach_profile.slug) : coaches_path %>
          <% thumb = lesson_thumbnail_url(lesson) %>
          <%= link_to open_path, class: "video-card #{'video-card-locked' if access_level == :locked}" do %>
            <div class="video-thumb">
              <% if thumb.present? %>
                <img src="<%= thumb %>" alt="<%= lesson.title %> cover" class="video-thumb__img" loading="lazy" />
              <% else %>
                <div class="thumb-placeholder">
                  <span class="play-icon">▶</span>
                </div>
              <% end %>
              <div class="thumb-overlay">
                <% if learning_state_label.present? %>
                  <span class="badge video-card__status video-card__status--<%= learning_state_class %>"><%= learning_state_label %></span>
                <% end %>
              </div>
            </div>
            <div class="video-meta">
              <div class="video-title"><%= truncate(lesson.title, length: 70) %></div>
              <div class="video-subtitle">by <%= coach_name %></div>
              <div class="video-info">
                <%= learning_state_label || "Available now" %>
                <span class="muted">• <%= time_ago_in_words(lesson.created_at) %> ago</span>
              </div>
              <% if learning_state == :locked && access_level == :preview && lesson.preview_text.present? %>
                <div class="video-snippet"><%= truncate(lesson.preview_text, length: 90) %></div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>
    <% end %>
</div>
