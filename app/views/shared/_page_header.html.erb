<%# locals:
    breadcrumbs: array of [label, url] pairs (optional)
    title: string (required)
    subtitle: string (optional)
    primary_action: { label:, url:, method: nil } (optional)
    secondary_actions: array of { label:, url:, method: nil } (optional)
    meta: array of { label:, value: } (optional)
%>
<div class="page-header card">
  <div class="page-header__main">
    <% if local_assigns[:breadcrumbs].present? %>
      <nav class="page-header__breadcrumbs" aria-label="Breadcrumb">
        <% breadcrumbs.each_with_index do |(label, url), idx| %>
          <% if url.present? %>
            <%= link_to label, url, class: "crumb" %>
          <% else %>
            <span class="crumb"><%= label %></span>
          <% end %>
          <% if idx < breadcrumbs.size - 1 %>
            <span class="crumb-sep">›</span>
          <% end %>
        <% end %>
      </nav>
    <% end %>

    <div class="page-header__title-wrap">
      <h1 class="page-header__title"><%= title %></h1>
    </div>
    <% if local_assigns[:subtitle].present? %>
      <p class="page-header__subtitle"><%= subtitle %></p>
    <% end %>

    <% if local_assigns[:meta].present? %>
      <div class="page-header__meta">
        <% meta.each do |chip| %>
          <span class="chip chip-meta chip--neutral page-header__meta-chip">
            <span class="page-header__meta-label"><%= chip[:label] %></span>
            <strong class="page-header__meta-value"><%= chip[:value] %></strong>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if local_assigns[:primary_action].present? || local_assigns[:secondary_actions].present? %>
    <div class="page-header__actions">
      <% Array(local_assigns[:secondary_actions]).each do |action| %>
        <% action_class = action[:class].presence || "btn btn-ghost" %>
        <% if action[:method].present? && action[:method].to_s.downcase != "get" %>
          <%= button_to action[:label], action[:url], method: action[:method], form: { class: "inline-form" }, class: action_class %>
        <% else %>
          <%= link_to action[:label], action[:url], method: action[:method], class: action_class %>
        <% end %>
      <% end %>

      <% if local_assigns[:primary_action].present? %>
        <% primary_class = primary_action[:class].presence || "btn btn-primary" %>
        <% if primary_action[:method].present? && primary_action[:method].to_s.downcase != "get" %>
          <%= button_to primary_action[:label], primary_action[:url], method: primary_action[:method], form: { class: "inline-form" }, class: primary_class %>
        <% else %>
          <%= link_to primary_action[:label], primary_action[:url], method: primary_action[:method], class: primary_class %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
