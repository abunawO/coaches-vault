<div class="container favorites-library">
  <div class="favorites-library__inner">
    <div class="favorites-library__intro">
      <%= render "shared/page_header",
                 breadcrumbs: [["Dashboard", root_path], ["Favorites", favorites_path]],
                 title: content_tag(:span, "⭐️", class: "page-title-icon") + " Your Favorites",
                 subtitle: "Jump back into saved lessons through a more visual study library." %>
    </div>

    <% if @favorites.any? %>
      <section class="favorites-library__grid" aria-label="Favorite lessons">
        <% @favorites.each do |favorite| %>
          <% lesson = favorite.lesson %>
          <% thumbnail = lesson_thumbnail_url(lesson) %>
          <% coach_name = lesson.coach&.coach_profile&.display_name.presence || lesson.coach&.email || "Coach" %>
          <% step_count = lesson.lesson_media.size %>

          <article class="favorite-lesson-card">
            <%= link_to lesson_path(lesson),
                        class: "favorite-lesson-card__media-link",
                        aria: { label: "Open lesson #{lesson.title}" } do %>
              <div class="favorite-lesson-card__media">
                <% if thumbnail.present? %>
                  <%= image_tag thumbnail,
                                alt: "#{lesson.title} thumbnail",
                                class: "favorite-lesson-card__image",
                                loading: "lazy",
                                decoding: "async" %>
                <% else %>
                  <div class="favorite-lesson-card__placeholder" aria-hidden="true">
                    <span class="favorite-lesson-card__placeholder-mark">MCV</span>
                    <span class="favorite-lesson-card__placeholder-label">Lesson Library</span>
                  </div>
                <% end %>

                <% if step_count.positive? %>
                  <div class="favorite-lesson-card__badge">
                    <span class="chip-status badge"><%= pluralize(step_count, "step") %></span>
                  </div>
                <% end %>
              </div>
            <% end %>

            <div class="favorite-lesson-card__body">
              <p class="favorite-lesson-card__coach muted">by <%= coach_name %></p>
              <h2 class="favorite-lesson-card__title">
                <%= link_to lesson.title, lesson_path(lesson), class: "favorite-lesson-card__title-link" %>
              </h2>
            </div>

            <div class="favorite-lesson-card__footer">
              <%= link_to "Open lesson",
                          lesson_path(lesson),
                          class: "btn btn-primary btn-small favorite-lesson-card__primary-action" %>
              <%= button_to "Unfavorite",
                            unfavorite_lesson_path(lesson),
                            method: :delete,
                            class: "btn btn-ghost btn-small favorite-lesson-card__secondary-action",
                            form: { class: "favorite-lesson-card__unfavorite-form" } %>
            </div>
          </article>
        <% end %>
      </section>
    <% else %>
      <%= render "shared/empty_state",
                 icon: "☆",
                 title: "No favorites yet",
                 body: "Save lessons to build a quick-return study library.",
                 primary_action: { label: "Browse coaches", url: coaches_path } %>
    <% end %>
  </div>
</div>
