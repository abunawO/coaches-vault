<!DOCTYPE html>
<html>

<head>
    <title><%= content_for(:title) || "MyCoachVault" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="MyCoachVault">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
</head>

<% auth_controllers = %w[sessions registrations password_resets] %>
<% body_classes = [controller_name, action_name, ('auth-page' if auth_controllers.include?(controller_name))].compact.join(' ') %>

<body class="<%= body_classes %>">
    <div class="toast-stack" data-controller="flash">
        <% flash.each do |type, message| %>
        <div class="toast toast-<%= type %>" data-flash-target="toast">
            <span class="toast-message"><%= message %></span>
            <button type="button" class="toast-close" aria-label="Close" data-action="flash#dismiss">&times;</button>
        </div>
        <% end %>
    </div>

    <header class="topnav" data-controller="topnav">
        <div class="topnav__inner">
            <div class="topnav__bar">
                <div class="topnav__brand">
                    <% student_has_nav_alerts =
              logged_in? &&
              current_user.student? &&
              (
                current_user.unread_messages_count.to_i.positive? ||
                current_user.unread_notifications_count.to_i.positive?
              )
            %>
                    <% brand_path =
              if logged_in? && current_user.student?
                root_path
              elsif logged_in? && current_user.coach?
                coach_vault_path
              else
                root_path
              end
            %>
                    <%= link_to brand_path, class: "topnav__brand-link", aria: { label: "MyCoachVault home" } do %>
                    <span class="topnav__brand-mark" aria-hidden="true">MCV</span>
                    <span class="topnav__brand-copy">
                        <span class="topnav__brand-name">MyCoachVault</span>
                        <span class="topnav__brand-tag">Structured learning vaults</span>
                    </span>
                    <% end %>
                </div>

                <nav class="topnav__nav topnav__primary" aria-label="Primary">
                    <div class="topnav__links" data-topnav-target="desktopLinks">
                        <% if logged_in? %>
                        <% if current_user.student? %>
                        <%= link_to "Dashboard", root_path, class: "topnav__link #{nav_link_class(root_path)}" %>
                        <%= link_to "Vaults", student_my_vaults_path, class: "topnav__link #{nav_link_class(student_my_vaults_path)}" %>
                        <%= link_to "Coaches", coaches_path, class: "topnav__link #{nav_link_class(coaches_path)}" %>
                        <%= link_to "Search", search_path, class: "topnav__link #{nav_link_class(search_path)}" %>
                        <% elsif current_user.coach? %>
                        <%= link_to "Dashboard", root_path, class: "topnav__link #{nav_link_class(root_path)}" %>
                        <%= link_to "My Lessons", coach_lessons_path, class: "topnav__link #{nav_link_class(coach_lessons_path)}" %>
                        <%= link_to "Content", coach_content_path, class: "topnav__link #{nav_link_class(coach_content_path)}" %>
                        <%= link_to "Insights", coach_insights_path, class: "topnav__link #{nav_link_class(coach_insights_path)}" %>
                        <% end %>
                        <% else %>
                        <%= link_to "Coaches", coaches_path, class: "topnav__link #{nav_link_class(coaches_path)}" %>
                        <%= link_to "Search", search_path, class: "topnav__link #{nav_link_class(search_path)}" %>
                        <%= link_to "Sign up", signup_path, class: "topnav__link #{nav_link_class(signup_path)}" %>
                        <%= link_to "Login", login_path, class: "topnav__link #{nav_link_class(login_path)}" %>
                        <% end %>
                    </div>

                    <% if !logged_in? || current_user.coach? || current_user.student? %>
                    <div class="topnav__more <%= 'topnav__more--desktop' if logged_in? %> <%= 'topnav__more--student' if logged_in? && current_user.student? %>" data-topnav-target="moreWrap">
                        <button type="button" class="topnav__moreBtn" data-action="click->topnav#toggleMore" aria-expanded="false">
                            More ▾
                        </button>
                        <div class="topnav__moreMenu" data-topnav-target="moreMenu" hidden>
                            <% if logged_in? %>
                            <% if current_user.student? %>
                            <%= link_to "Subscriptions", subscriptions_path, class: "topnav__moreLink #{nav_link_class(subscriptions_path)}" %>
                            <%= link_to "Favorites", favorites_path, class: "topnav__moreLink #{nav_link_class(favorites_path)}" %>
                            <%= link_to conversations_path, class: "topnav__moreLink #{nav_link_class(conversations_path)}" do %>
                            Messages
                            <%= render "shared/nav_badge",
                                       id: "nav_messages_badge",
                                       count: current_user.unread_messages_count,
                                       extra_class: "topnav__badge--inline" %>
                            <% end %>
                            <%= link_to notifications_path, class: "topnav__moreLink #{nav_link_class(notifications_path)}" do %>
                            Notifications
                            <%= render "shared/nav_badge",
                                       id: "nav_notifications_badge",
                                       count: current_user.unread_notifications_count,
                                       extra_class: "topnav__badge--inline" %>
                            <% end %>
                            <% elsif current_user.coach? %>
                            <%= link_to conversations_path, class: "topnav__moreLink #{nav_link_class(conversations_path)}" do %>
                            Messages
                            <%= render "shared/nav_badge",
                                       id: "nav_messages_badge",
                                       count: current_user.unread_messages_count,
                                       extra_class: "topnav__badge--inline" %>
                            <% end %>
                            <%= link_to notifications_path, class: "topnav__moreLink #{nav_link_class(notifications_path)}" do %>
                            Notifications
                            <%= render "shared/nav_badge",
                                       id: "nav_notifications_badge",
                                       count: current_user.unread_notifications_count,
                                       extra_class: "topnav__badge--inline" %>
                            <% end %>
                            <%= link_to "Subscribers", subscribers_path, class: "topnav__moreLink #{nav_link_class(subscribers_path)}" %>
                            <% end %>
                            <% else %>
                            <%= link_to "Login", login_path, class: "topnav__moreLink #{nav_link_class(login_path)}" %>
                            <% end %>
                        </div>
                    </div>
                    <% end %>
                </nav>

                <div class="topnav__account">
                    <% if logged_in? %>
                    <div class="topnav__user">
                        <span class="topnav__signedin">Signed in as</span>
                        <span class="topnav__email"><%= current_user.display_name %></span>
                    </div>
                    <%= button_to "Logout", logout_path, method: :delete, form: { class: "inline-form" }, class: "btn btn-secondary" %>
                    <% end %>
                    <button class="topnav__toggle topnav__hamburger <%= "topnav__hamburger--has-alert" if student_has_nav_alerts %>" type="button" aria-label="Toggle navigation" aria-expanded="false" data-action="click->topnav#toggle" data-topnav-target="toggle">
                        <span class="topnav__toggle-bar"></span>
                        <span class="topnav__toggle-bar"></span>
                        <span class="topnav__toggle-bar"></span>
                        <% if student_has_nav_alerts %>
                        <span class="topnav__hamburger-alert" aria-hidden="true"></span>
                        <% end %>
                    </button>
                </div>
            </div>

            <% if logged_in? && current_user.student? %>
            <nav class="topnav__student-quick" aria-label="Student quick actions">
                <%= link_to "Vaults", student_my_vaults_path, class: "topnav__student-quick-link #{'is-active' if current_page?(student_my_vaults_path)}" %>
                <%= link_to "Coaches", coaches_path, class: "topnav__student-quick-link #{'is-active' if current_page?(coaches_path)}" %>
                <%= link_to "Search", search_path, class: "topnav__student-quick-link #{'is-active' if current_page?(search_path)}" %>
                <%= link_to notifications_path, class: "topnav__student-quick-link #{'is-active' if current_page?(notifications_path)}" do %>
                <span class="topnav__student-quick-label topnav__student-quick-label--short">Alerts</span>
                <% if current_user.unread_notifications_count.positive? %>
                <span class="topnav__badge topnav__student-quick-badge" aria-label="<%= current_user.unread_notifications_count %> unread notifications">
                    <%= current_user.unread_notifications_count %>
                </span>
                <% end %>
                <% end %>
            </nav>
            <% end %>

            <div class="topnav__panel" data-topnav-target="menu">
                <nav class="topnav__links topnav__links--mobile" aria-label="Mobile primary">
                    <% if logged_in? %>
                    <% if current_user.student? %>
                    <%= link_to "Dashboard", root_path, class: "topnav__link #{nav_link_class(root_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to "Subscriptions", subscriptions_path, class: "topnav__link #{nav_link_class(subscriptions_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to "Favorites", favorites_path, class: "topnav__link #{nav_link_class(favorites_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to conversations_path, class: "topnav__link #{nav_link_class(conversations_path)}", data: { action: "click->topnav#close" } do %>
                    Messages
                    <% if current_user.unread_messages_count.positive? %>
                    <span class="topnav__badge"><%= current_user.unread_messages_count %></span>
                    <% end %>
                    <% end %>
                    <% elsif current_user.coach? %>
                    <%= link_to "Dashboard", root_path, class: "topnav__link #{nav_link_class(root_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to "My Lessons", coach_lessons_path, class: "topnav__link #{nav_link_class(coach_lessons_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to "Content", coach_content_path, class: "topnav__link #{nav_link_class(coach_content_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to "Insights", coach_insights_path, class: "topnav__link #{nav_link_class(coach_insights_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to conversations_path, class: "topnav__link #{nav_link_class(conversations_path)}", data: { action: "click->topnav#close" } do %>
                    Messages
                    <% if current_user.unread_messages_count.positive? %>
                    <span class="topnav__badge"><%= current_user.unread_messages_count %></span>
                    <% end %>
                    <% end %>
                    <%= link_to notifications_path, class: "topnav__link #{nav_link_class(notifications_path)}", data: { action: "click->topnav#close" } do %>
                    Notifications
                    <% if current_user.unread_notifications_count.positive? %>
                    <span class="topnav__badge"><%= current_user.unread_notifications_count %></span>
                    <% end %>
                    <% end %>
                    <%= link_to "Subscribers", subscribers_path, class: "topnav__link #{nav_link_class(subscribers_path)}", data: { action: "click->topnav#close" } %>
                    <% end %>
                    <% else %>
                    <%= link_to "Coaches", coaches_path, class: "topnav__link #{nav_link_class(coaches_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to "Search", search_path, class: "topnav__link #{nav_link_class(search_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to "Sign up", signup_path, class: "topnav__link #{nav_link_class(signup_path)}", data: { action: "click->topnav#close" } %>
                    <%= link_to "Login", login_path, class: "topnav__link #{nav_link_class(login_path)}", data: { action: "click->topnav#close" } %>
                    <% end %>
                </nav>
                <div class="topnav__panel-divider"></div>
                <% if logged_in? %>
                <div class="topnav__panel-account">
                    <div class="topnav__user">
                        <span class="topnav__signedin">Signed in as</span>
                        <span class="topnav__email"><%= current_user.display_name %></span>
                    </div>
                    <%= button_to "Logout", logout_path, method: :delete, form: { class: "inline-form" }, class: "btn btn-secondary btn-full" %>
                </div>
                <% end %>
            </div>
        </div>
    </header>

    <main class="page" data-controller="confirm-modal">
        <%= render "shared/confirm_modal" %>
        <%= yield %>
    </main>
</body>

</html>
