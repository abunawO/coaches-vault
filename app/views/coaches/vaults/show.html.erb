<% initial_selected_section_id = params[:category_id].present? ? @selected_section_id : nil %>

<div
  class="container coach-vault coach-vault--student"
  data-controller="student-vault"
  data-student-vault-initial-section-id-value="<%= initial_selected_section_id %>"
>
  <%= render "coaches/vaults/vault_header",
      coach_profile: @coach_profile,
      coach: @coach,
      subscribed: @subscribed,
      owning_coach: @owning_coach,
      preview_mode: @preview_mode,
      preview_return_to: @preview_return_to,
      total_categories: @vault_sections.size,
      total_lessons: @total_lessons %>

  <% if @vault_sections.empty? %>
    <div class="card coach-vault__empty-state">
      <h3 class="coach-vault__empty-title">Vault is still being organized</h3>
      <p class="muted">This coach has not published any section yet.</p>
    </div>
  <% else %>
    <div class="coach-vault__toolbar card">
      <div class="coach-vault__toolbar-summary" data-student-vault-target="resultsSummary">
        Explore <strong data-student-vault-target="resultsCount"><%= @total_lessons %></strong> lessons across this vault
      </div>
      <div class="coach-vault__toolbar-search">
        <label class="small-text muted" for="vault-search-input">Search lessons in this vault</label>
        <div class="coach-vault__search-row">
          <input
            id="vault-search-input"
            type="search"
            class="input coach-vault__search"
            placeholder="Search lessons, concepts, or systems..."
            data-student-vault-target="searchInput"
            data-action="input->student-vault#filter"
            aria-label="Search lessons in this coach vault"
          >
          <button
            type="button"
            class="btn btn-secondary btn-small is-hidden"
            data-student-vault-target="clearButton"
            data-action="student-vault#clearSearch"
          >
            Clear
          </button>
        </div>
        <div class="coach-vault__type-filters" role="group" aria-label="Filter by training area">
          <button
            type="button"
            class="pill-soft coach-vault__type-filter is-active"
            data-student-vault-target="typeFilter"
            data-type="all"
            data-action="student-vault#selectType"
          >
            All
          </button>
          <% @available_types.each do |category_type| %>
            <button
              type="button"
              class="pill-soft coach-vault__type-filter"
              data-student-vault-target="typeFilter"
              data-type="<%= category_type %>"
              data-action="student-vault#selectType"
            >
              <%= category_type %>
            </button>
          <% end %>
        </div>
      </div>
    </div>

    <div class="coach-vault__workspace">
      <aside class="vault-rail card" aria-label="Vault sections">
        <div>
          <h3 class="vault-rail__heading vault-rail__title">Section Index</h3>
          <% @sections_by_type.each do |category_type, sections| %>
            <section class="vault-rail__group" data-student-vault-target="typeGroup" data-category-type="<%= category_type %>">
              <button
                type="button"
                class="vault-rail__group-toggle"
                data-action="student-vault#toggleGroup"
                aria-expanded="false"
              >
                <span class="vault-rail__heading vault-rail__group-label"><%= category_type %></span>
                <span class="vault-rail__group-chevron" aria-hidden="true"></span>
              </button>
              <div class="vault-rail__list">
                <% sections.each do |section| %>
                  <%= render "coaches/vaults/vault_nav_item", section: section, selected_section_id: initial_selected_section_id %>
                <% end %>
              </div>
            </section>
          <% end %>
        </div>
      </aside>

      <section class="vault-main" aria-live="polite">
        <div class="card coach-vault__empty-state" data-student-vault-target="noSelection">
          <h3 class="coach-vault__empty-title">Select a section to begin</h3>
          <p class="muted">Expand a category in Section Index and choose a section to view lessons.</p>
        </div>

        <% @vault_sections.each do |section| %>
          <%= render "coaches/vaults/vault_section",
              section: section,
              coach: @coach,
              coach_profile: @coach_profile,
              selected: section[:category].id == initial_selected_section_id %>
        <% end %>

        <div class="card coach-vault__empty-state is-hidden" data-student-vault-target="noResults">
          <h3 class="coach-vault__empty-title">No lessons match your search</h3>
          <p class="muted">Try broader keywords or clear your search.</p>
        </div>
      </section>
    </div>
  <% end %>
</div>
