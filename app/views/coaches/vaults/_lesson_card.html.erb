<% access = lesson.viewer_access_level(current_user) %>
<% locked = access != :full %>
<% link_target = locked ? (logged_in? ? coach_subscription_path(coach) : login_path) : public_coach_lesson_path(coach_profile.slug, lesson, category_id: section_id) %>
<% link_options = locked && logged_in? ? { method: :post } : {} %>
<% searchable = [lesson.title, lesson.description].compact.join(" ").downcase %>
<% thumbnail = lesson_thumbnail_url(lesson) %>
<% lesson_view = current_user&.student? ? @lesson_views_by_lesson_id.to_h[lesson.id] : nil %>
<% learning_state = lesson.learning_state_for(current_user, access_level: access, lesson_view: lesson_view) %>
<% learning_state_class = learning_state.to_s.tr("_", "-") %>
<% learning_state_label =
  case learning_state
  when :locked then "Locked"
  when :new then "New"
  else nil
  end %>
<% learning_meta_copy =
  case learning_state
  when :locked then "Subscribe to unlock"
  when :new then "Recently added"
  else "Available now"
  end %>

<%= link_to link_target, link_options.merge(class: "vault-lesson-card #{'is-locked' if locked}", data: { student_vault_target: "lessonCard", search: searchable, section_id: section_id }) do %>
  <div class="vault-lesson-card__media">
    <% if thumbnail.present? %>
      <img
        src="<%= thumbnail %>"
        alt="<%= lesson.title %> preview image"
        class="vault-lesson-card__image"
        loading="lazy"
        decoding="async"
      >
    <% else %>
      <div class="vault-lesson-card__image-placeholder" aria-hidden="true">
        <span class="vault-lesson-card__placeholder-label">Lesson Preview</span>
      </div>
    <% end %>
    <div class="vault-lesson-card__media-badge">
      <% if learning_state_label.present? %>
        <span class="badge vault-lesson-card__status vault-lesson-card__status--<%= learning_state_class %>"><%= learning_state_label %></span>
      <% end %>
    </div>
  </div>

  <div class="vault-lesson-card__body">
    <div class="vault-lesson-card__title"><%= lesson.title %></div>
    <div class="vault-lesson-card__meta muted small-text">
      <span class="vault-lesson-card__date"><%= l(lesson.created_at, format: :short) %></span>
      <span aria-hidden="true">•</span>
      <span><%= learning_meta_copy %></span>
    </div>
  </div>

  <% if locked %>
    <div class="vault-lesson-card__lock" aria-hidden="true">🔒</div>
  <% end %>
<% end %>
