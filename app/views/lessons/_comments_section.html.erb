<section class="comments-card card" data-controller="comment-edit-modal">
  <% viewer_is_coach_owner = current_user&.coach? && current_user.id == lesson.coach_id %>
  <% viewer_is_student = current_user&.student? %>
  <% discussion_intro =
    if can_comment
      "Ask questions about this lesson, share your takeaways, and join the discussion."
    elsif viewer_is_coach_owner
      "Student questions and discussion about this lesson will appear here. Reply to guide your students."
    elsif viewer_is_student
      "Discussion is available to subscribed students. Subscribe to ask questions and join in."
    else
      "This is where students discuss the lesson and ask questions."
    end %>

  <div class="section-header">
    <div>
      <h2 class="page-title">Questions & Discussion</h2>
      <p class="muted"><%= discussion_intro %></p>
    </div>
  </div>

  <% if root_comments.any? %>
    <div class="comment-list">
      <% root_comments.each do |comment| %>
        <div class="comment-card" id="comment-<%= comment.id %>">
          <div class="comment-header">
            <div class="avatar"><%= comment.user.email.first.upcase %></div>
            <div>
              <p class="comment-author"><%= comment.user.email %></p>
              <p class="muted">Student comment</p>
            </div>
          </div>

          <p><%= comment.body %></p>

          <% if current_user && comment.user_id == current_user.id %>
            <div class="card-actions" style="justify-content: flex-end; gap: 8px; margin-top: 8px;">
              <button type="button"
                class="icon-btn"
                data-action="comment-edit-modal#open"
                data-edit-title="Edit comment"
                data-edit-submit-label="Save"
                data-edit-action="<%= lesson_comment_path(lesson, comment) %>"
                data-edit-body="<%= comment.body %>"
                aria-label="Edit comment"
                data-tooltip="Edit">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 20h9"/>
                  <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4Z"/>
                </svg>
              </button>
              <button type="button"
                class="icon-btn icon-btn--danger"
                data-action="confirm-modal#open"
                data-confirm-title="Delete comment?"
                data-confirm-body="This will permanently delete your comment."
                data-confirm-action="<%= lesson_comment_path(lesson, comment) %>"
                data-confirm-method="delete"
                data-confirm-label="Delete"
                aria-label="Delete comment"
                data-tooltip="Delete">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6v12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
                  <path d="M10 11v6"/>
                  <path d="M14 11v6"/>
                  <path d="M15 6V4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v2"/>
                </svg>
              </button>
            </div>
          <% end %>

          <% if comment.replies.any? %>
            <div class="reply-list">
              <% comment.replies.each do |reply| %>
                <div class="comment-card reply-card">
                  <div class="comment-header">
                    <div class="avatar coach-avatar"><%= reply.user.email.first.upcase %></div>
                    <div>
                      <p class="comment-author"><%= reply.user.email %></p>
                      <p class="muted">Coach reply</p>
                    </div>
                  </div>

                  <p><%= reply.body %></p>

                  <% if current_user && reply.user_id == current_user.id %>
                    <div class="card-actions" style="justify-content: flex-end; gap: 8px; margin-top: 8px;">
                      <button type="button"
                        class="icon-btn"
                        data-action="comment-edit-modal#open"
                        data-edit-title="Edit reply"
                        data-edit-submit-label="Save"
                        data-edit-action="<%= lesson_comment_path(lesson, reply) %>"
                        data-edit-body="<%= reply.body %>"
                        aria-label="Edit reply"
                        data-tooltip="Edit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <path d="M12 20h9"/>
                          <path d="M16.5 3.5a2.121 2.121 0 1 1 3 3L7 19l-4 1 1-4Z"/>
                        </svg>
                      </button>
                      <button type="button"
                        class="icon-btn icon-btn--danger"
                        data-action="confirm-modal#open"
                        data-confirm-title="Delete reply?"
                        data-confirm-body="This will permanently delete your reply."
                        data-confirm-action="<%= lesson_comment_path(lesson, reply) %>"
                        data-confirm-method="delete"
                        data-confirm-label="Delete"
                        aria-label="Delete reply"
                        data-tooltip="Delete">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                          <polyline points="3 6 5 6 21 6"/>
                          <path d="M19 6v12a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/>
                          <path d="M10 11v6"/>
                          <path d="M14 11v6"/>
                          <path d="M15 6V4a2 2 0 0 0-2-2h-2a2 2 0 0 0-2 2v2"/>
                        </svg>
                      </button>
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>

          <% if can_reply %>
            <%= form_with model: [lesson, Comment.new], local: true, class: "comment-form" do |f| %>
              <%= f.hidden_field :parent_id, value: comment.id %>
              <div class="form-row">
                <%= f.label :body, "Reply" %>
                <%= f.text_area :body, rows: 2, required: true, class: "textarea" %>
              </div>
              <div class="card-actions" style="justify-content: flex-end;">
                <%= f.submit "Reply", class: "btn btn-secondary" %>
              </div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <% empty_copy =
      if can_comment
        "No questions yet. Start the discussion by asking your first question."
      elsif viewer_is_coach_owner
        "No student questions yet. When students comment on this lesson, they will appear here."
      elsif viewer_is_student
        "No discussion is visible yet. Subscribe to this coach to join the conversation."
      else
        "No discussion yet."
      end %>
    <div class="empty-state"><%= empty_copy %></div>
  <% end %>

  <% if can_comment %>
    <div class="card comment-form-card">
      <h3 class="card-title">Ask a question</h3>
      <%= form_with model: [lesson, Comment.new], local: true do |f| %>
        <div class="form-row">
          <%= f.label :body, "Your question or insight" %>
          <%= f.text_area :body, rows: 3, required: true, class: "textarea" %>
        </div>
        <div class="card-actions" style="justify-content: flex-end;">
          <%= f.submit "Post to discussion", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  <% elsif viewer_is_coach_owner %>
    <div class="empty-state">You can reply when students ask questions in this lesson discussion.</div>
  <% elsif logged_in? && viewer_is_student %>
    <div class="empty-state">
      <p class="muted" style="margin: 0 0 8px;">Subscribe to this coach to ask questions and join the lesson discussion.</p>
      <%= button_to "Subscribe to join discussion", coach_subscription_path(lesson.coach), method: :post, class: "btn btn-primary" %>
    </div>
  <% end %>

  <div class="modal-backdrop" data-comment-edit-modal-target="dialog" hidden data-action="click->comment-edit-modal#backdrop">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="edit-comment-modal-title">
      <div class="modal-header">
        <h3 id="edit-comment-modal-title" data-comment-edit-modal-target="title">Edit comment</h3>
        <button type="button" class="modal-close" data-action="comment-edit-modal#close" aria-label="Close">×</button>
      </div>
      <div class="modal-body">
        <form method="post" data-comment-edit-modal-target="form" action="#">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <input type="hidden" name="_method" value="patch">
          <div class="form-row">
            <label for="comment-edit-body">Your comment</label>
            <textarea id="comment-edit-body" name="comment[body]" rows="4" required class="textarea" data-comment-edit-modal-target="textarea"></textarea>
          </div>
          <div class="modal-actions">
            <button type="button" class="btn btn-secondary" data-action="comment-edit-modal#close">Cancel</button>
            <button type="submit" class="btn btn-primary" data-comment-edit-modal-target="submitLabel">Save</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>
