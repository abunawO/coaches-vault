# OS and editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Ruby / Bundler
/.bundle
/vendor/bundle
.byebug_history

# Environment and secrets
/.env
/.env.*
!/.env.example
!/.env.sample
/config/master.key
/config/credentials/*.key

# Logs and runtime files
/log/*
!/log/.keep
/tmp/*
!/tmp/.keep

# Keep these runtime directories in git, ignore their generated contents
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep
/tmp/cache/*
!/tmp/cache/
!/tmp/cache/.keep
/tmp/sockets/*
!/tmp/sockets/
!/tmp/sockets/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Uploaded files
/storage/*
!/storage/.keep

# Database files
/db/*.sqlite3
/db/*.sqlite3-*

# Build outputs and caches
/public/assets
/public/packs
/public/packs-test
/coverage

# Node / JS
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# Asset builds (keep tracked placeholders/artifacts as needed)
/app/assets/builds/*
!/app/assets/builds/.keep
!/app/assets/builds/uppy_bundle.js
